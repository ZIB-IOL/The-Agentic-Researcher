#!/bin/bash
#
# agentic-researcher: Launch an AI coding agent in a sandboxed container.
# Usage: agentic-researcher [OPTIONS] [DIRECTORY] [TOOL_OPTIONS...]
# Run with --help for details.
#

set -e
SCRIPT_PATH="${BASH_SOURCE[0]}"
if [[ -L "$SCRIPT_PATH" ]]; then
    SCRIPT_PATH="$(python3 -c 'import os, sys; print(os.path.realpath(sys.argv[1]))' "$SCRIPT_PATH")"
fi
SCRIPT_DIR="$(cd "$(dirname "$SCRIPT_PATH")" && pwd)"
USER=${USER:-$(whoami)}

capture_env_overrides() {
    local var override_var unset_marker="__AR_UNSET__"
    local override_vars=(
        AR_CONTAINER_RUNTIME
        AR_CLI_TOOL
        AR_DEFAULT_MODEL
        AR_STATE_ROOT
        AR_EXTRA_BIND_DIRS
        AR_DOCKER_GPUS
        AR_AUTH_MODE
        AR_API_PROVIDER
        AR_API_KEY_ENV
        AR_CUSTOM_ENDPOINT
        AR_CUSTOM_ANTHROPIC_ENDPOINT
        AR_HTTPS_PROXY
        AR_HTTP_PROXY
    )

    for var in "${override_vars[@]}"; do
        override_var="${var}_ENV_OVERRIDE"
        if [[ -n "${!var+x}" ]]; then
            printf -v "$override_var" '%s' "${!var}"
        else
            printf -v "$override_var" '%s' "$unset_marker"
        fi
    done
}

load_config() {
    local cfg="$HOME/.config/agentic-researcher/config.sh"
    if [[ -f "$cfg" ]]; then
        source "$cfg"
    fi
}

# Environment variables override config file values
apply_env_overrides() {
    local var override_var
    local override_vars=(
        AR_CONTAINER_RUNTIME
        AR_CLI_TOOL
        AR_DEFAULT_MODEL
        AR_STATE_ROOT
        AR_EXTRA_BIND_DIRS
        AR_DOCKER_GPUS
        AR_AUTH_MODE
        AR_API_PROVIDER
        AR_API_KEY_ENV
        AR_CUSTOM_ENDPOINT
        AR_CUSTOM_ANTHROPIC_ENDPOINT
        AR_HTTPS_PROXY
        AR_HTTP_PROXY
    )

    for var in "${override_vars[@]}"; do
        override_var="${var}_ENV_OVERRIDE"
        if [[ "${!override_var:-__AR_UNSET__}" != "__AR_UNSET__" ]]; then
            printf -v "$var" '%s' "${!override_var}"
        fi
    done

    if [[ -n "${AR_CONTAINER_RUNTIME_OVERRIDE:-}" ]]; then
        AR_CONTAINER_RUNTIME="$AR_CONTAINER_RUNTIME_OVERRIDE"
    fi
    if [[ -n "${AR_CLI_TOOL_OVERRIDE:-}" ]]; then
        AR_CLI_TOOL="$AR_CLI_TOOL_OVERRIDE"
    fi
    if [[ -n "${AR_DEFAULT_MODEL_OVERRIDE:-}" ]]; then
        AR_DEFAULT_MODEL="$AR_DEFAULT_MODEL_OVERRIDE"
    fi
}

apply_defaults() {
    AR_CONTAINER_RUNTIME="${AR_CONTAINER_RUNTIME:-docker}"
    AR_CLI_TOOL="${AR_CLI_TOOL:-claude}"
    AR_STATE_ROOT="${AR_STATE_ROOT:-$HOME/.cache/agentic-researcher}"
    AR_EXTRA_BIND_DIRS="${AR_EXTRA_BIND_DIRS:-}"
    AR_DOCKER_GPUS="${AR_DOCKER_GPUS:-auto}"

    case "$AR_CLI_TOOL" in
        claude)
            AR_AUTH_MODE="${AR_AUTH_MODE:-oauth}"
            AR_API_PROVIDER="${AR_API_PROVIDER:-anthropic}"
            AR_API_KEY_ENV="${AR_API_KEY_ENV:-ANTHROPIC_API_KEY}"
            AR_DEFAULT_MODEL="${AR_DEFAULT_MODEL:-sonnet}"
            ;;
        opencode)
            AR_AUTH_MODE="${AR_AUTH_MODE:-tool}"
            ;;
        gemini)
            AR_AUTH_MODE="${AR_AUTH_MODE:-tool}"
            ;;
        codex)
            AR_AUTH_MODE="${AR_AUTH_MODE:-tool}"
            ;;
    esac
}
YOLO_MODE=false
TEST_MODE=false
MODEL_SPECIFIED=false
DEBUG_LAUNCH=false
WORKSPACE_DIR=""
TOOL_ARGS=()

parse_arguments() {
    while [[ $# -gt 0 ]]; do
        case $1 in
            --setup)
                shift
                exec "$SCRIPT_DIR/scripts/first-setup.sh" "$@"
                ;;
            --build)
                load_config
                apply_env_overrides
                apply_defaults
                exec "$SCRIPT_DIR/container/build.sh" \
                    ${AR_CONTAINER_RUNTIME:+--$AR_CONTAINER_RUNTIME}
                ;;
            --clean)
                shift
                exec "$SCRIPT_DIR/scripts/cleanup.sh" "$@"
                ;;
            --uninstall)
                shift
                exec "$SCRIPT_DIR/scripts/uninstall.sh" "$@"
                ;;
            --test)
                TEST_MODE=true
                shift
                ;;
            --debug-launch)
                DEBUG_LAUNCH=true
                shift
                ;;
            --docker)
                AR_CONTAINER_RUNTIME_OVERRIDE="docker"
                shift
                ;;
            --apptainer)
                AR_CONTAINER_RUNTIME_OVERRIDE="apptainer"
                shift
                ;;
            --tool)
                if [[ -z "${2:-}" || "$2" =~ ^- ]]; then
                    echo "Error: --tool requires a value (claude|opencode|gemini|codex)"
                    exit 1
                fi
                AR_CLI_TOOL_OVERRIDE="$2"
                shift 2
                ;;
            --yolo)
                YOLO_MODE=true
                shift
                ;;
            --help|-h)
                show_help
                exit 0
                ;;
            --resume|-r)
                if [[ -n "${2:-}" && ! "$2" =~ ^- ]]; then
                    TOOL_ARGS+=("--resume" "$2")
                    shift 2
                else
                    TOOL_ARGS+=("--resume")
                    shift
                fi
                ;;
            --continue|-c)
                TOOL_ARGS+=("--continue")
                shift
                ;;
            --model)
                MODEL_SPECIFIED=true
                if [[ -z "${2:-}" || "$2" =~ ^- ]]; then
                    echo "Error: --model requires a value"
                    exit 1
                fi
                TOOL_ARGS+=("$1" "$2")
                shift 2
                ;;
            --context)
                if [[ -z "${2:-}" || "$2" =~ ^- ]]; then
                    echo "Error: --context requires a value"
                    exit 1
                fi
                TOOL_ARGS+=("$1" "$2")
                shift 2
                ;;
            -*)
                TOOL_ARGS+=("$1")
                shift
                ;;
            *)
                if [[ -z "$WORKSPACE_DIR" ]]; then
                    WORKSPACE_DIR="$1"
                else
                    TOOL_ARGS+=("$1")
                fi
                shift
                ;;
        esac
    done
}

show_help() {
    cat << 'EOF'
agentic-researcher: Launch an AI coding agent in a sandboxed container
                    for autonomous research.

Usage:
  agentic-researcher [OPTIONS] [DIRECTORY] [TOOL_OPTIONS...]

Options:
  --setup             Run the optional interactive setup wizard
  --build             Build or rebuild the container image
  --clean             Remove launcher-managed local state
  --uninstall         Remove the installed launcher and optional local state
  --docker            Force Docker runtime for this invocation
  --apptainer         Force Apptainer runtime for this invocation
  --test              Quick validation of sandbox environment
  --debug-launch      Print extra launcher details and enable tool startup logs where supported
  --tool TOOL         Select CLI tool (claude|opencode|gemini|codex)
  --yolo              Auto-approve all permissions (Claude Code only)
  --resume [ID]       Resume a session (interactive picker, or specify ID)
  --continue, -c      Continue the most recent conversation
  --model MODEL       Override default model
  DIRECTORY           Project directory to work in (default: current directory)
  TOOL_OPTIONS        Additional options passed to the CLI tool

Examples:
  agentic-researcher --build                      # Build default container
  agentic-researcher --docker --build             # Build Docker container
  agentic-researcher --apptainer --build          # Build Apptainer container
  agentic-researcher --setup                      # Optional setup wizard
  agentic-researcher --clean                      # Interactive cleanup of local state
  agentic-researcher --uninstall                  # Remove installed launcher
  agentic-researcher --clean --yes --include-config
  agentic-researcher --test                       # Validate environment
  agentic-researcher --tool opencode --debug-launch
  agentic-researcher                              # Current directory
  agentic-researcher ~/my-project                 # Specific directory
  agentic-researcher --yolo                       # Auto-approve (Claude)
  agentic-researcher --tool gemini                # Use Gemini CLI
  agentic-researcher --tool codex ~/project       # Use Codex CLI
  agentic-researcher --yolo --model opus          # YOLO + Opus

What's Sandboxed:
  The agent can ONLY access your project directory.
  Cannot read/write files outside the project.
  Cannot access home directory, SSH keys, etc.
  Even with --yolo, the agent stays sandboxed.

Security:
  --yolo auto-approves tool calls but maintains filesystem isolation.
  OpenCode/Gemini/Codex have no built-in permission system.
  Review changes before committing to git.
EOF
}
validate_workspace() {
    # Default to current directory
    if [[ -z "$WORKSPACE_DIR" ]]; then
        WORKSPACE_DIR="$(pwd)"
    fi

    # Resolve symlinks in a macOS/Linux portable way.
    if ! WORKSPACE_DIR="$(python3 -c 'import os, sys; print(os.path.realpath(sys.argv[1]))' "$WORKSPACE_DIR" 2>/dev/null)"; then
        echo "Error: Cannot resolve path: $WORKSPACE_DIR"
        exit 1
    fi

    if [[ ! -d "$WORKSPACE_DIR" ]]; then
        echo "Error: Directory does not exist: $WORKSPACE_DIR"
        exit 1
    fi

    # SECURITY: Prevent sandboxing of sensitive system directories
    case "$WORKSPACE_DIR" in
        /|/etc/*|/etc|/root/*|/root|/sys/*|/sys|/proc/*|/proc|/dev/*|/dev|/boot/*|/boot)
            echo "Error: Cannot sandbox system directories: $WORKSPACE_DIR"
            exit 1
            ;;
        /home/*/.ssh/*|/home/*/.ssh|/Users/*/.ssh/*|/Users/*/.ssh)
            echo "Error: Cannot sandbox SSH directories: $WORKSPACE_DIR"
            exit 1
            ;;
        /home/*/.claude/*|/home/*/.claude|/Users/*/.claude/*|/Users/*/.claude)
            echo "Error: Cannot sandbox Claude config directories: $WORKSPACE_DIR"
            exit 1
            ;;
        /home/*/.gnupg/*|/home/*/.gnupg|/Users/*/.gnupg/*|/Users/*/.gnupg)
            echo "Error: Cannot sandbox GPG directories: $WORKSPACE_DIR"
            exit 1
            ;;
        /home/*/.aws/*|/home/*/.aws|/home/*/.kube/*|/home/*/.kube|/home/*/.config/gcloud/*|/home/*/.config/gcloud|/Users/*/.aws/*|/Users/*/.aws|/Users/*/.kube/*|/Users/*/.kube|/Users/*/.config/gcloud/*|/Users/*/.config/gcloud)
            echo "Error: Cannot sandbox cloud credential directories: $WORKSPACE_DIR"
            exit 1
            ;;
    esac
}

validate_api_key() {
    # Tool-managed auth and OAuth are handled inside the CLI itself.
    if [[ "$AR_CLI_TOOL" != "claude" || "${AR_AUTH_MODE:-tool}" == "tool" || "${AR_AUTH_MODE:-tool}" == "oauth" ]]; then
        return
    fi
    local key_var="${AR_API_KEY_ENV:-ANTHROPIC_API_KEY}"
    if [[ -z "${!key_var:-}" ]]; then
        echo "Error: $key_var environment variable is not set."
        echo ""
        echo "Either set your API key:"
        echo "  export $key_var='your-api-key-here'"
        echo ""
        echo "Or switch to OAuth login:"
        echo "  agentic-researcher --setup  (select 'oauth' for authentication)"
        exit 1
    fi
}
validate_apptainer_host() {
    local host_os
    host_os="$(uname -s)"

    if [[ "$host_os" != "Linux" ]]; then
        echo "Error: Apptainer is only supported on Linux hosts. Current host: $host_os"
        echo ""
        echo "Use Docker on this machine instead:"
        echo "  agentic-researcher --docker ..."
        echo ""
        echo "To test Apptainer, run the launcher on a Linux workstation, WSL2 instance, or cluster node."
        exit 1
    fi

    if ! command -v apptainer >/dev/null 2>&1; then
        echo "Error: Apptainer runtime selected, but 'apptainer' is not installed or not on PATH."
        echo ""
        echo "Install Apptainer on the Linux host, then rerun:"
        echo "  agentic-researcher --apptainer --build"
        exit 1
    fi
}

validate_container() {
    if [[ "$AR_CONTAINER_RUNTIME" == "apptainer" ]]; then
        validate_apptainer_host
        CONTAINER_IMAGE="$SCRIPT_DIR/container/agentic_researcher.sif"
        if [[ ! -f "$CONTAINER_IMAGE" ]]; then
            echo "Error: Container image not found: $CONTAINER_IMAGE"
            echo ""
            echo "Build the container first:"
            echo "  agentic-researcher --build"
            exit 1
        fi

        # SECURITY: Verify container integrity if checksum exists
        if [[ -f "$CONTAINER_IMAGE.sha256" ]]; then
            if ! (cd "$SCRIPT_DIR/container" && sha256sum -c "agentic_researcher.sif.sha256" &>/dev/null); then
                echo "Error: Container image integrity check failed!"
                echo "The container may have been tampered with."
                exit 1
            fi
        else
            echo "Warning: No checksum file found. Skipping integrity verification."
        fi

        # Check pty-wrapper
        if [[ ! -x "$SCRIPT_DIR/scripts/pty-wrapper.py" ]]; then
            echo "Error: pty-wrapper.py not found or not executable"
            exit 1
        fi
    fi
    # Docker validation happens at launch time
}
setup_storage() {
    STATE_ROOT="${AR_STATE_ROOT:-$HOME/.cache/agentic-researcher}"

    UV_CACHE_DIR="$STATE_ROOT/uv/cache"
    UV_PYTHON_INSTALL_DIR="$STATE_ROOT/uv/python"
    UV_TOOL_DIR="$STATE_ROOT/uv/tools"

    # Sandbox-specific config directory (isolated from host)
    AR_CONFIG_STORE="$STATE_ROOT/agentic-researcher-config"
    CLAUDE_JSON="$AR_CONFIG_STORE/claude.json"

    mkdir -p "$UV_CACHE_DIR" "$UV_PYTHON_INSTALL_DIR" "$UV_TOOL_DIR" \
             "$AR_CONFIG_STORE" "$AR_CONFIG_STORE/commands"

    # Ensure claude.json exists (required for onboarding bypass)
    if [[ ! -f "$CLAUDE_JSON" ]]; then
        echo '{"hasCompletedOnboarding": true}' > "$CLAUDE_JSON"
    fi

    # Apptainer cache
    if [[ "$AR_CONTAINER_RUNTIME" == "apptainer" ]]; then
        export APPTAINER_CACHEDIR="$STATE_ROOT/apptainer_cache"
        mkdir -p -m 700 "$APPTAINER_CACHEDIR"

        CONTAINER_TMP="$STATE_ROOT/apptainer_cache/container-tmp"
        mkdir -p -m 700 "$CONTAINER_TMP"
    fi

    CACHE_BASE="$STATE_ROOT"
    HF_HOME="$CACHE_BASE/hf_home"
    TRITON_CACHE_DIR="$CACHE_BASE/triton_cache"
    mkdir -p "$HF_HOME" "$TRITON_CACHE_DIR"

    OPENCODE_STATE_DIR="$STATE_ROOT/opencode"
    OPENCODE_CONFIG_DIR="$OPENCODE_STATE_DIR/config"
    OPENCODE_DATA_DIR="$OPENCODE_STATE_DIR/data"
    GEMINI_STATE_DIR="$HOME/.gemini"
    CODEX_STATE_DIR="$HOME/.codex"
    mkdir -p "$OPENCODE_CONFIG_DIR" "$OPENCODE_DATA_DIR" "$GEMINI_STATE_DIR" "$CODEX_STATE_DIR"

    mkdir -p \
        "$GEMINI_STATE_DIR/commands" \
        "$GEMINI_STATE_DIR/skills" \
        "$GEMINI_STATE_DIR/agents" \
        "$GEMINI_STATE_DIR/history" \
        "$GEMINI_STATE_DIR/tmp/bin"
    if [[ ! -f "$GEMINI_STATE_DIR/projects.json" ]]; then
        printf '{\n  "projects": {}\n}\n' > "$GEMINI_STATE_DIR/projects.json"
    fi
    if [[ ! -f "$GEMINI_STATE_DIR/settings.json" ]]; then
        printf '{}\n' > "$GEMINI_STATE_DIR/settings.json"
    fi
}
render_instruction_template() {
    local output_path="$1"

    if [[ "$AR_CONTAINER_RUNTIME" == "docker" ]]; then
        awk '
            /<!-- DOCKER-OMIT-START -->/ { skip=1; next }
            /<!-- DOCKER-OMIT-END -->/   { skip=0; next }
            !skip { print }
        ' "$SCRIPT_DIR/INSTRUCTIONS.md" > "$output_path"
    else
        cp "$SCRIPT_DIR/INSTRUCTIONS.md" "$output_path"
    fi
}
setup_instruction_file() {
    # Map CLI tool to instruction file name in a Bash 3-compatible way.
    local target="CLAUDE.md"
    case "$AR_CLI_TOOL" in
        claude)
            target="CLAUDE.md"
            ;;
        opencode|codex)
            target="AGENTS.md"
            ;;
        gemini)
            target="GEMINI.md"
            ;;
    esac

    # Copy template to workspace if target doesn't exist
    if [[ -f "$SCRIPT_DIR/INSTRUCTIONS.md" ]] && [[ ! -f "$WORKSPACE_DIR/$target" ]]; then
        render_instruction_template "$WORKSPACE_DIR/$target"
    fi

    INSTRUCTION_TARGET="$target"
}
strip_command_frontmatter() {
    local source_path="$1"

    awk '
        NR == 1 && $0 == "---" { in_frontmatter=1; next }
        in_frontmatter && $0 == "---" { in_frontmatter=0; next }
        !in_frontmatter { print }
    ' "$source_path"
}
render_codex_skill() {
    local skill_name="$1"
    local description="$2"
    local source_path="$3"
    local target_path="$4"
    local temp_path="${target_path}.tmp"

    {
        printf -- '---\n'
        printf 'name: "%s"\n' "$skill_name"
        printf 'description: "%s"\n' "$description"
        printf -- '---\n\n'
        printf '<!-- Generated by agentic-researcher. Edit commands/%s.md to change this skill. -->\n\n' "$skill_name"
        printf 'This project skill mirrors the `%s` research command.\n\n' "$skill_name"
        printf 'If the user supplied extra text alongside this skill invocation, treat that text as the command argument.\n\n'
        strip_command_frontmatter "$source_path" \
            | sed 's/\$ARGUMENTS/any extra user text that accompanied the skill invocation/g'
    } > "$temp_path"

    mv "$temp_path" "$target_path"
}
setup_codex_project_skills() {
    CODEX_PROJECT_SKILLS_DIR="$WORKSPACE_DIR/.agents/skills"
    mkdir -p "$CODEX_PROJECT_SKILLS_DIR"

    local managed_marker="Generated by agentic-researcher"
    local skill_name description source_path skill_dir target_path

    while IFS='|' read -r skill_name description; do
        source_path="$SCRIPT_DIR/commands/$skill_name.md"
        if [[ ! -f "$source_path" ]]; then
            continue
        fi

        skill_dir="$CODEX_PROJECT_SKILLS_DIR/$skill_name"
        target_path="$skill_dir/SKILL.md"

        if [[ -f "$target_path" ]] && ! grep -q "$managed_marker" "$target_path"; then
            echo "Warning: Skipping existing Codex skill at $target_path (not managed by agentic-researcher)"
            continue
        fi

        mkdir -p "$skill_dir"
        render_codex_skill "$skill_name" "$description" "$source_path" "$target_path"
    done << 'EOF'
setup_research_plan|Set up or resume a research project in this workspace
retro|Reflect on the current research session and propose instruction improvements
update_base|Update the project instruction file from the latest base template
EOF
}
translate_tool_args() {
    local tool="$AR_CLI_TOOL"

    case "$tool" in
        claude)
            if [[ "$MODEL_SPECIFIED" == "false" && -n "${AR_DEFAULT_MODEL:-}" ]]; then
                TOOL_ARGS+=("--model" "$AR_DEFAULT_MODEL")
            fi
            if [[ "$YOLO_MODE" == "true" ]]; then
                TOOL_ARGS+=("--dangerously-skip-permissions")
            fi
            ;;
        opencode)
            # Translate Claude-style flags to OpenCode equivalents
            local translated=()
            local skip_next=false
            for ((i=0; i<${#TOOL_ARGS[@]}; i++)); do
                if [[ "$skip_next" == "true" ]]; then
                    skip_next=false
                    continue
                fi
                local arg="${TOOL_ARGS[$i]}"
                case "$arg" in
                    --dangerously-skip-permissions)
                        echo "Warning: --yolo has no effect in OpenCode mode"
                        ;;
                    --resume)
                        local next="${TOOL_ARGS[$((i+1))]:-}"
                        if [[ -n "$next" && ! "$next" =~ ^- ]]; then
                            translated+=("--session" "$next")
                            skip_next=true
                        else
                            echo "Warning: --resume without ID not supported in OpenCode"
                        fi
                        ;;
                    --context)
                        skip_next=true
                        echo "Warning: --context not supported in OpenCode"
                        ;;
                    *)
                        translated+=("$arg")
                        ;;
                esac
            done
            TOOL_ARGS=("${translated[@]}")
            if [[ "$MODEL_SPECIFIED" == "false" && -n "${AR_DEFAULT_MODEL:-}" ]]; then
                TOOL_ARGS+=("--model" "$AR_DEFAULT_MODEL")
            fi
            if [[ "$DEBUG_LAUNCH" == "true" ]]; then
                TOOL_ARGS+=("--print-logs" "--log-level" "DEBUG")
            fi
            if [[ "$YOLO_MODE" == "true" ]]; then
                echo "Warning: --yolo has no effect in OpenCode mode (no permission system)"
            fi
            ;;
        gemini)
            if [[ "$MODEL_SPECIFIED" == "false" && -n "${AR_DEFAULT_MODEL:-}" ]]; then
                TOOL_ARGS+=("--model" "$AR_DEFAULT_MODEL")
            fi
            if [[ " ${TOOL_ARGS[*]} " != *" --sandbox "* ]]; then
                TOOL_ARGS+=("--sandbox=false")
            fi
            if [[ "$DEBUG_LAUNCH" == "true" ]]; then
                TOOL_ARGS+=("--debug")
            fi
            if [[ "$YOLO_MODE" == "true" ]]; then
                TOOL_ARGS+=("--yolo")
            fi
            ;;
        codex)
            if [[ "$MODEL_SPECIFIED" == "false" && -n "${AR_DEFAULT_MODEL:-}" ]]; then
                TOOL_ARGS+=("--model" "$AR_DEFAULT_MODEL")
            fi
            if [[ "$YOLO_MODE" == "true" ]]; then
                TOOL_ARGS+=("--full-auto")
            fi
            ;;
    esac
}
setup_auth_binds() {
    SSH_BIND=()
    GIT_SSH_COMMAND="ssh"

    if [[ -d "$HOME/.ssh" ]]; then
        SSH_BIND=(--bind "$HOME/.ssh:/claude-home/.ssh:ro")

        # Parse proxy for SSH tunneling
        local proxy_url="${AR_HTTPS_PROXY:-${HTTPS_PROXY:-${https_proxy:-}}}"
        local proxy_host proxy_port
        proxy_host=$(echo "$proxy_url" | sed 's|^https\?://||; s|:.*||')
        proxy_port=$(echo "$proxy_url" | sed 's|^https\?://[^:]*:||; s|/.*||')

        if [[ -n "$proxy_host" && -n "$proxy_port" ]]; then
            SSH_BIND+=(--bind "$SCRIPT_DIR/scripts/ssh-proxy-connect.py:/ssh-proxy-connect.py:ro")
            GIT_SSH_COMMAND="ssh -o ProxyCommand='/ssh-proxy-connect.py ${proxy_host} ${proxy_port} %h %p'"
        fi
    fi

    if [[ -f "$HOME/.gitconfig" ]]; then
        SSH_BIND+=(--bind "$HOME/.gitconfig:/claude-home/.gitconfig:ro")
    fi
    if [[ -f "$HOME/.bashrc" ]]; then
        SSH_BIND+=(--bind "$HOME/.bashrc:/claude-home/.bashrc:ro")
    fi
}
setup_research_binds() {
    RESEARCH_BINDS=()
    for cmd_file in setup_research_plan retro update_base; do
        if [[ -f "$SCRIPT_DIR/commands/$cmd_file.md" ]]; then
            RESEARCH_BINDS+=(--bind "$SCRIPT_DIR/commands/$cmd_file.md:/claude-home/.claude/commands/$cmd_file.md:ro")
        fi
    done
    if [[ -f "$SCRIPT_DIR/INSTRUCTIONS.md" ]]; then
        RESEARCH_BINDS+=(--bind "$SCRIPT_DIR/INSTRUCTIONS.md:/claude-home/.claude/INSTRUCTIONS.md.template:ro")
    fi
}
sanitize_mount_name() {
    local raw_name="$1"
    local sanitized

    sanitized="$(printf '%s' "$raw_name" | tr -c 'A-Za-z0-9._-' '_')"
    if [[ -z "$sanitized" ]]; then
        sanitized="mount"
    fi

    printf '%s\n' "$sanitized"
}
setup_workspace_mount_root() {
    WORKSPACE_MOUNT_PLACEHOLDER_DIR="$WORKSPACE_DIR/.mount"
    WORKSPACE_MOUNT_STATE_DIR="$STATE_ROOT/workspace-mounts/$(printf '%s' "$WORKSPACE_DIR" | cksum | awk '{print $1}')"

    mkdir -p "$WORKSPACE_MOUNT_PLACEHOLDER_DIR" "$WORKSPACE_MOUNT_STATE_DIR"
    EXTRA_DIR_ROOT_BIND=(--bind "$WORKSPACE_MOUNT_STATE_DIR:/workspace/.mount")
}
setup_optional_binds() {
    DATASET_BINDS=()

    # Extra directories from config (colon-separated after normalization)
    EXTRA_DIR_ROOT_BIND=()
    EXTRA_DIR_BINDS=()
    EXTRA_DIR_DEBUG_MOUNTS=()
    if [[ -n "${AR_EXTRA_BIND_DIRS:-}" ]]; then
        local used_mount_names=()

        # Normalize: accept commas, spaces, or colons as separators
        local normalized
        normalized=$(echo "$AR_EXTRA_BIND_DIRS" | tr ',' ':' | tr ' ' ':' | sed 's/::/:/g; s/^://; s/:$//')
        IFS=':' read -ra dirs <<< "$normalized"
        setup_workspace_mount_root
        for dir in "${dirs[@]}"; do
            local mount_name host_mount_dir container_mount_dir

            [[ -z "$dir" ]] && continue
            if [[ "$dir" == "$WORKSPACE_DIR/.mount" || "$dir" == "$WORKSPACE_DIR/.mount/"* ]]; then
                echo "Warning: Skipping extra bind inside reserved workspace mount root: $dir"
                continue
            fi
            if [[ -d "$dir" ]]; then
                mount_name="$(sanitize_mount_name "$(basename "$dir")")"
                if [[ " ${used_mount_names[*]} " == *" $mount_name "* ]]; then
                    echo "Warning: Skipping extra bind with duplicate mount name '$mount_name': $dir"
                    continue
                fi

                used_mount_names+=("$mount_name")
                host_mount_dir="$WORKSPACE_MOUNT_STATE_DIR/$mount_name"
                container_mount_dir="/workspace/.mount/$mount_name"
                mkdir -p "$host_mount_dir"

                EXTRA_DIR_BINDS+=(--bind "$dir:$container_mount_dir")
                EXTRA_DIR_DEBUG_MOUNTS+=("$dir -> $container_mount_dir")
            else
                echo "Warning: Extra bind directory not found: $dir"
            fi
        done
    fi
}
setup_opencode() {
    OPENCODE_COMMANDS_DIR="$OPENCODE_CONFIG_DIR/commands"
    mkdir -p "$OPENCODE_DATA_DIR" "$OPENCODE_CONFIG_DIR" "$OPENCODE_COMMANDS_DIR"

    # Generate opencode config from template if custom endpoint is set
    local oc_config="$OPENCODE_CONFIG_DIR/opencode.json"
    if [[ -n "${AR_CUSTOM_ENDPOINT:-}" && -f "$SCRIPT_DIR/config/opencode_config.template.json" ]]; then
        local api_key="${!AR_API_KEY_ENV:-}"
        sed -e "s|__AR_CUSTOM_ENDPOINT__|$AR_CUSTOM_ENDPOINT|g" \
            -e "s|__AR_API_KEY__|$api_key|g" \
            "$SCRIPT_DIR/config/opencode_config.template.json" > "$oc_config"
    fi
}
build_env_args() {
    ENV_ARGS=(
        --env UV_CACHE_DIR=/uv-cache
        --env UV_PYTHON_INSTALL_DIR=/uv-python
        --env UV_TOOL_DIR=/uv-tools
        --env UV_LINK_MODE=symlink
        --env "HF_HOME=$HF_HOME"
        --env "TRITON_CACHE_DIR=$TRITON_CACHE_DIR"
        --env "TERM=${TERM:-xterm-256color}"
        --env "USER=$USER"
        --env "GIT_SSH_COMMAND=$GIT_SSH_COMMAND"
    )

    # Standard API key pass-through so CLIs can handle auth inside the container.
    for env_name in ANTHROPIC_API_KEY OPENAI_API_KEY GOOGLE_API_KEY GEMINI_API_KEY; do
        if [[ -n "${!env_name:-}" ]]; then
            ENV_ARGS+=(--env "${env_name}=${!env_name}")
        fi
    done

    # If AR_API_KEY_ENV names a non-standard var, forward it as ANTHROPIC_API_KEY.
    local _ar_key_var="${AR_API_KEY_ENV:-ANTHROPIC_API_KEY}"
    if [[ "$_ar_key_var" != "ANTHROPIC_API_KEY" && -n "${!_ar_key_var:-}" && -z "${ANTHROPIC_API_KEY:-}" ]]; then
        ENV_ARGS+=(--env "ANTHROPIC_API_KEY=${!_ar_key_var}")
    fi

    # Proxy
    if [[ -n "${AR_HTTPS_PROXY:-}" ]]; then
        ENV_ARGS+=(--env "https_proxy=$AR_HTTPS_PROXY" --env "http_proxy=${AR_HTTP_PROXY:-$AR_HTTPS_PROXY}")
    elif [[ -n "${HTTPS_PROXY:-}" ]]; then
        ENV_ARGS+=(--env "https_proxy=$HTTPS_PROXY" --env "http_proxy=${HTTP_PROXY:-$HTTPS_PROXY}")
    fi

    # Tool-specific env vars
    case "$AR_CLI_TOOL" in
        claude)
            if [[ -n "${AR_CUSTOM_ANTHROPIC_ENDPOINT:-}" ]]; then
                ENV_ARGS+=(--env "ANTHROPIC_BASE_URL=$AR_CUSTOM_ANTHROPIC_ENDPOINT")
            fi
            ;;
        opencode)
            ENV_ARGS+=(--env "SANDBOX_TOOL=opencode")
            ;;
        gemini)
            ENV_ARGS+=(--env "SANDBOX_TOOL=gemini")
            ;;
        codex)
            ENV_ARGS+=(--env "SANDBOX_TOOL=codex")
            ;;
    esac
}
print_debug_launch() {
    if [[ "$DEBUG_LAUNCH" != "true" ]]; then
        return
    fi

    echo "Launch debug:"
    echo "  Runtime:        $AR_CONTAINER_RUNTIME"
    echo "  Tool:           $AR_CLI_TOOL"
    echo "  Workspace:      $WORKSPACE_DIR"
    echo "  State root:     $STATE_ROOT"
    if [[ "$AR_CONTAINER_RUNTIME" == "docker" ]]; then
        echo "  Docker image:   agentic-researcher:latest"
    else
        echo "  Container:      $CONTAINER_IMAGE"
    fi
    echo "  Tool args:      ${TOOL_ARGS[*]:-(none)}"
    if [[ ${#EXTRA_DIR_DEBUG_MOUNTS[@]} -gt 0 ]]; then
        echo "  Extra mounts:"
        for mount_line in "${EXTRA_DIR_DEBUG_MOUNTS[@]}"; do
            echo "    $mount_line"
        done
    fi
    echo ""
}
launch_apptainer() {
    local mode="${1:-run}"  # run or test

    local BIND_ARGS=(
        --nv
        --compat
        --no-mount home
        --home /claude-home
        "${SSH_BIND[@]}"
        --bind "$WORKSPACE_DIR:/workspace"
        --bind "$UV_CACHE_DIR:/uv-cache"
        --bind "$UV_PYTHON_INSTALL_DIR:/uv-python"
        --bind "$UV_TOOL_DIR:/uv-tools"
        --bind "$CONTAINER_TMP:/tmp"
        --bind "$STATE_ROOT:$STATE_ROOT"
        "${DATASET_BINDS[@]}"
        "${EXTRA_DIR_ROOT_BIND[@]}"
        "${EXTRA_DIR_BINDS[@]}"
        --pwd /workspace
    )

    # Claude/OpenCode-specific binds
    case "$AR_CLI_TOOL" in
        claude)
            BIND_ARGS+=(
                --bind "$AR_CONFIG_STORE:/claude-home/.claude"
                --bind "$CLAUDE_JSON:/claude-home/.claude.json"
                "${RESEARCH_BINDS[@]}"
            )
            ;;
        opencode)
            if [[ -d "${OPENCODE_CONFIG_DIR:-}" ]]; then
                BIND_ARGS+=(--bind "$OPENCODE_CONFIG_DIR:/claude-home/.config/opencode")
            fi
            if [[ -d "${OPENCODE_DATA_DIR:-}" ]]; then
                BIND_ARGS+=(--bind "$OPENCODE_DATA_DIR:/claude-home/.local/share/opencode")
            fi
            if [[ -f "$SCRIPT_DIR/INSTRUCTIONS.md" ]]; then
                BIND_ARGS+=(--bind "$SCRIPT_DIR/INSTRUCTIONS.md:/claude-home/.claude/INSTRUCTIONS.md.template:ro")
            fi
            ;;
        gemini)
            if [[ -d "${GEMINI_STATE_DIR:-}" ]]; then
                BIND_ARGS+=(--bind "$GEMINI_STATE_DIR:/claude-home/.gemini")
            fi
            ;;
        codex)
            if [[ -d "${CODEX_STATE_DIR:-}" ]]; then
                BIND_ARGS+=(--bind "$CODEX_STATE_DIR:/claude-home/.codex")
            fi
            if [[ -f "$SCRIPT_DIR/INSTRUCTIONS.md" ]]; then
                BIND_ARGS+=(--bind "$SCRIPT_DIR/INSTRUCTIONS.md:/claude-home/.claude/INSTRUCTIONS.md.template:ro")
            fi
            ;;
    esac

    if [[ "$mode" == "test" ]]; then
        BIND_ARGS+=(
            --bind "$SCRIPT_DIR/scripts/test_sandbox.sh:/test_sandbox.sh:ro"
        )
        # Pass tool info for tool-specific tests
        ENV_ARGS+=(--env "AR_CLI_TOOL=$AR_CLI_TOOL")

        apptainer exec \
            "${BIND_ARGS[@]}" \
            "${ENV_ARGS[@]}" \
            "$CONTAINER_IMAGE" \
            /bin/bash /test_sandbox.sh
    else
        "$SCRIPT_DIR/scripts/pty-wrapper.py" apptainer run \
            "${BIND_ARGS[@]}" \
            "${ENV_ARGS[@]}" \
            "$CONTAINER_IMAGE" \
            "${TOOL_ARGS[@]}"
    fi
}
launch_docker() {
    local mode="${1:-run}"
    local host_uid host_gid host_user host_group
    host_uid="$(id -u)"
    host_gid="$(id -g)"
    host_user="$(id -un)"
    host_group="$(id -gn)"

    local DOCKER_ARGS=(
        docker run --rm -it
        --init
        -v "$WORKSPACE_DIR:/workspace"
        -v "$UV_CACHE_DIR:/uv-cache"
        -v "$UV_PYTHON_INSTALL_DIR:/uv-python"
        -v "$UV_TOOL_DIR:/uv-tools"
        -v "$STATE_ROOT:$STATE_ROOT"
        -w /workspace
    )

    # Only request Docker GPU support when the host plausibly has an NVIDIA runtime.
    case "${AR_DOCKER_GPUS:-auto}" in
        all)
            DOCKER_ARGS+=(--gpus all)
            ;;
        auto)
            if [[ "$(uname -s)" == "Linux" ]] && command -v nvidia-smi >/dev/null 2>&1; then
                DOCKER_ARGS+=(--gpus all)
            fi
            ;;
        none)
            ;;
    esac

    # Extra bind dirs
    for dir_bind in "${EXTRA_DIR_ROOT_BIND[@]}" "${EXTRA_DIR_BINDS[@]}"; do
        [[ -n "$dir_bind" ]] || continue
        # Convert --bind X:Y to -v X:Y
        DOCKER_ARGS+=(-v "${dir_bind#--bind }")
    done

    # Convert env args
    DOCKER_ARGS+=(
        -e "UV_CACHE_DIR=/uv-cache"
        -e "UV_PYTHON_INSTALL_DIR=/uv-python"
        -e "UV_TOOL_DIR=/uv-tools"
        -e "UV_LINK_MODE=symlink"
        -e "HF_HOME=$HF_HOME"
        -e "TRITON_CACHE_DIR=$TRITON_CACHE_DIR"
        -e "TERM=${TERM:-xterm-256color}"
        -e "HOME=/claude-home"
        -e "HOST_UID=$host_uid"
        -e "HOST_GID=$host_gid"
        -e "HOST_USER=$host_user"
        -e "HOST_GROUP=$host_group"
        -e "SANDBOX_TOOL=$AR_CLI_TOOL"
    )

    for env_name in ANTHROPIC_API_KEY OPENAI_API_KEY GOOGLE_API_KEY GEMINI_API_KEY; do
        if [[ -n "${!env_name:-}" ]]; then
            DOCKER_ARGS+=(-e "${env_name}=${!env_name}")
        fi
    done

    # If AR_API_KEY_ENV names a non-standard var, forward it as ANTHROPIC_API_KEY.
    local _ar_key_var="${AR_API_KEY_ENV:-ANTHROPIC_API_KEY}"
    if [[ "$_ar_key_var" != "ANTHROPIC_API_KEY" && -n "${!_ar_key_var:-}" && -z "${ANTHROPIC_API_KEY:-}" ]]; then
        DOCKER_ARGS+=(-e "ANTHROPIC_API_KEY=${!_ar_key_var}")
    fi

    # Proxy
    if [[ -n "${AR_HTTPS_PROXY:-}" ]]; then
        DOCKER_ARGS+=(-e "https_proxy=$AR_HTTPS_PROXY" -e "http_proxy=${AR_HTTP_PROXY:-$AR_HTTPS_PROXY}")
    fi

    # Tool-specific
    #
    # Docker Desktop on macOS does not support nested bind mounts (mounting a
    # file into a path that is already inside a bind-mounted directory).
    # Instead, copy files into $AR_CONFIG_STORE before mounting the directory.
    case "$AR_CLI_TOOL" in
        claude)
            for cmd_file in setup_research_plan retro update_base; do
                if [[ -f "$SCRIPT_DIR/commands/$cmd_file.md" ]]; then
                    cp "$SCRIPT_DIR/commands/$cmd_file.md" "$AR_CONFIG_STORE/commands/$cmd_file.md"
                fi
            done
            if [[ -f "$SCRIPT_DIR/INSTRUCTIONS.md" ]]; then
                render_instruction_template "$AR_CONFIG_STORE/INSTRUCTIONS.md.template"
            fi
            DOCKER_ARGS+=(
                -v "$AR_CONFIG_STORE:/claude-home/.claude"
                -v "$CLAUDE_JSON:/claude-home/.claude.json"
            )
            if [[ -n "${AR_CUSTOM_ANTHROPIC_ENDPOINT:-}" ]]; then
                DOCKER_ARGS+=(-e "ANTHROPIC_BASE_URL=$AR_CUSTOM_ANTHROPIC_ENDPOINT")
            fi
            ;;
        opencode)
            if [[ -d "${OPENCODE_CONFIG_DIR:-}" ]]; then
                for cmd_file in setup_research_plan retro update_base; do
                    if [[ -f "$SCRIPT_DIR/commands/$cmd_file.md" ]]; then
                        mkdir -p "$OPENCODE_CONFIG_DIR/commands"
                        cp "$SCRIPT_DIR/commands/$cmd_file.md" "$OPENCODE_CONFIG_DIR/commands/$cmd_file.md"
                    fi
                done
                DOCKER_ARGS+=(-v "$OPENCODE_CONFIG_DIR:/claude-home/.config/opencode")
            fi
            if [[ -d "${OPENCODE_DATA_DIR:-}" ]]; then
                DOCKER_ARGS+=(-v "$OPENCODE_DATA_DIR:/claude-home/.local/share/opencode")
            fi
            if [[ -f "$SCRIPT_DIR/INSTRUCTIONS.md" ]]; then
                render_instruction_template "$AR_CONFIG_STORE/INSTRUCTIONS.md.template"
                DOCKER_ARGS+=(-v "$AR_CONFIG_STORE:/claude-home/.claude")
            fi
            ;;
        gemini)
            if [[ -d "${GEMINI_STATE_DIR:-}" ]]; then
                DOCKER_ARGS+=(-v "$GEMINI_STATE_DIR:/claude-home/.gemini")
            fi
            ;;
        codex)
            if [[ -d "${CODEX_STATE_DIR:-}" ]]; then
                DOCKER_ARGS+=(-v "$CODEX_STATE_DIR:/claude-home/.codex")
            fi
            if [[ -f "$SCRIPT_DIR/INSTRUCTIONS.md" ]]; then
                render_instruction_template "$AR_CONFIG_STORE/INSTRUCTIONS.md.template"
                DOCKER_ARGS+=(-v "$AR_CONFIG_STORE:/claude-home/.claude")
            fi
            ;;
    esac

    # SSH/git
    if [[ -d "$HOME/.ssh" ]]; then
        DOCKER_ARGS+=(-v "$HOME/.ssh:/claude-home/.ssh:ro")
    fi
    if [[ -f "$HOME/.gitconfig" ]]; then
        DOCKER_ARGS+=(-v "$HOME/.gitconfig:/claude-home/.gitconfig:ro")
    fi

    if [[ "$mode" == "test" ]]; then
        DOCKER_ARGS+=(-v "$SCRIPT_DIR/scripts/test_sandbox.sh:/test_sandbox.sh:ro")
        DOCKER_ARGS+=(-e "AR_CLI_TOOL=$AR_CLI_TOOL")
        "${DOCKER_ARGS[@]}" agentic-researcher:latest /bin/bash /test_sandbox.sh
    else
        "${DOCKER_ARGS[@]}" agentic-researcher:latest "${TOOL_ARGS[@]}"
    fi
}
main() {
    capture_env_overrides
    parse_arguments "$@"
    load_config
    apply_env_overrides
    apply_defaults
    validate_workspace
    validate_api_key
    validate_container
    setup_storage
    setup_instruction_file
    translate_tool_args
    setup_auth_binds
    setup_research_binds
    setup_optional_binds
    build_env_args
    print_debug_launch

    # Tool-specific setup
    if [[ "$AR_CLI_TOOL" == "opencode" ]]; then
        setup_opencode
    elif [[ "$AR_CLI_TOOL" == "codex" ]]; then
        setup_codex_project_skills
    fi

    # Display banner
    local tool_display
    case "$AR_CLI_TOOL" in
        claude)   tool_display="Claude Code" ;;
        opencode) tool_display="OpenCode" ;;
        gemini)   tool_display="Gemini CLI" ;;
        codex)    tool_display="Codex CLI" ;;
        *)        tool_display="$AR_CLI_TOOL" ;;
    esac

    local banner_width=64
    echo "╔$(printf '═%.0s' $(seq 1 $banner_width))╗"
    local title="Agentic Researcher - $tool_display"
    local pad=$(( banner_width - ${#title} - 7 ))
    printf "║       %s%*s║\n" "$title" "$pad" ""
    echo "╚$(printf '═%.0s' $(seq 1 $banner_width))╝"
    echo ""
    echo "Workspace:      $WORKSPACE_DIR"
    echo "Sandboxed:      Only /workspace is accessible"
    echo "UV Cache:       $UV_CACHE_DIR"

    if [[ "$YOLO_MODE" == "true" ]]; then
        echo "Mode:           YOLO (auto-approve enabled)"
    else
        echo "Mode:           Protected (manual approval required)"
    fi
    echo ""

    echo "Starting $tool_display..."
    echo "================================================================"
    echo ""

    # Launch
    if [[ "$AR_CONTAINER_RUNTIME" == "docker" ]]; then
        if [[ "$TEST_MODE" == "true" ]]; then
            launch_docker test
        else
            launch_docker run
        fi
    else
        if [[ "$TEST_MODE" == "true" ]]; then
            launch_apptainer test
        else
            launch_apptainer run
        fi
    fi
}

main "$@"
